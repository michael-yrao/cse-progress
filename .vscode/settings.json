{
  "python.analysis.diagnosticSeverityOverrides": {
    "reportOptionalMemberAccess": "none"
  },
  "editor.showFoldingControls": "always",
  "editor.foldingHighlight": true,
  "editor.foldingStrategy": "auto"

  // Prior-attempt spoilers are no longer hidden by a fold. On a retry,
  // scripts/new_problem.py MOVES the prior attempts out of the file into
  // <root>/.history/<n>_<name>.txt, so a retry opens on a blank page with nothing to
  // hide; scripts/restore_history.py pastes them back at session end. This needs no
  // extension and no editor config — it works in any editor, on GitHub, in a plain
  // diff — which is why all the Explicit Folding (zokugun.explicit-folding) rules that
  // used to live here, plus the mirrored copy in ../progressiveOverflow.code-workspace,
  // are gone. Native folding (def/if/for/docstrings) is handled by the language server.
}
